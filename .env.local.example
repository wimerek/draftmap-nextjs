# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must NEVER be committed.

# Airtable — server-side only (used by Route Handlers in app/api/)
# Get your Personal Access Token from: https://airtable.com/create/tokens
AIRTABLE_API_TOKEN=your_personal_access_token_here
AIRTABLE_BASE_ID=apphHlEBLATe8hrII
AIRTABLE_TABLE_ID=tblwqv6lrfmREuVt4

# Google Sheets — server-side only (no API key required; sheet must be public)
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# PostHog analytics — public vars, safe to expose to the browser
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# In production, set these in Vercel Dashboard → Project → Settings → Environment Variables
